rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdminEmail() {
      return request.auth != null
        && request.auth.token.isContentAdmin == true;
    }

    function isPublicReadCollection() {
      return resource == null
        || resource.data.status == 'published'
        || !('status' in resource.data);
    }

    match /noticias/{docId} {
      allow read: if isPublicReadCollection();
      allow create, update, delete: if isAdminEmail();
    }

    match /eventos/{docId} {
      allow read: if isPublicReadCollection();
      allow create, update, delete: if isAdminEmail();
    }

    match /musicas/{docId} {
      allow read: if isPublicReadCollection();
      allow create, update, delete: if isAdminEmail();
    }

    match /espiritualidades/{docId} {
      allow read: if isPublicReadCollection();
      allow create, update, delete: if isAdminEmail();
    }

    match /atividades/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdminEmail();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
